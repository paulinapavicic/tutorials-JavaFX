<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.paulina.tutorials.HelloController">

  <HBox alignment="CENTER_LEFT" spacing="15.0" VBox.vgrow="NEVER">
    <children>
      <Label text="Tutorials REST API Client" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="refreshButton" text="🔄 Refresh" onAction="#onRefreshClick" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
    </children>
    <padding><Insets top="20.0" left="20.0" right="20.0" bottom="15.0" /></padding>
  </HBox>


  <VBox spacing="15.0">
    <Label text="Create / Edit Tutorial" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />

    <GridPane hgap="15.0" vgap="12.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 8; -fx-padding: 20;">
      <children>
        <Label text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
        <TextField fx:id="titleField" promptText="Enter tutorial title" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="2" />


        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="descriptionField" promptText="Enter description" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2" />


        <CheckBox fx:id="publishedCheck" text="Published" GridPane.columnIndex="0" GridPane.rowIndex="2" />


        <Button fx:id="saveButton" text="➕ New" onAction="#onSaveClick" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.hgrow="NEVER"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button fx:id="updateButton" text="🔄 Update" onAction="#onUpdateClick" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.hgrow="NEVER"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button fx:id="deleteButton" text="🗑Delete" onAction="#onDeleteClick" GridPane.columnIndex="2" GridPane.rowIndex="3" GridPane.hgrow="NEVER"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button fx:id="clearButton" text="↻ Clear" onAction="#onClearForm" GridPane.columnIndex="3" GridPane.rowIndex="3" GridPane.hgrow="NEVER"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" />
      </children>
      <columnConstraints>
        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="ALWAYS" minWidth="250.0" />
        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="100.0" />
      </columnConstraints>
    </GridPane>
  </VBox>


  <TableView fx:id="tutorialsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
    <columns>
      <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
      <TableColumn fx:id="titleColumn" prefWidth="280.0" text="Title" />
      <TableColumn fx:id="descriptionColumn" prefWidth="380.0" text="Description" />
      <TableColumn fx:id="publishedColumn" prefWidth="100.0" text="Published" />
    </columns>
  </TableView>


  <Label fx:id="statusLabel" text="👆 Click Refresh or select row to edit"
         style="-fx-font-size: 14px; -fx-padding: 10; -fx-background-color: #d5dbdb; -fx-background-radius: 5;" />
</VBox>


